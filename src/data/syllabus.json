{
  "meta": {
    "version": "1.0",
    "description": "中学英語 統合スキル型シラバス（7スキル×中1-3）",
    "cefr_mapping": { "grade1": "A1", "grade2": "A2", "grade3": "B1" },
    "skills": ["vocabulary", "grammar", "listening", "speaking", "reading", "writing", "communication"]
  },
  "syllabus": {
    "vocabulary": {
      "description": "語彙力：単語・熟語・コロケーションの習得",
      "levels": [
        {
          "level": 1, "grade": 1, "cefr": "A1",
          "theme": "基本名詞・動詞・形容詞",
          "target_words": 300,
          "categories": [
            { "name": "身の回りのもの", "examples": ["desk", "chair", "book", "bag", "pen", "pencil", "eraser"] },
            { "name": "家族・人", "examples": ["father", "mother", "brother", "sister", "friend", "teacher"] },
            { "name": "動作", "examples": ["run", "walk", "eat", "drink", "study", "play", "watch"] },
            { "name": "形容詞", "examples": ["big", "small", "hot", "cold", "happy", "sad", "new", "old"] },
            { "name": "数・時間", "examples": ["one", "two", "Monday", "January", "morning", "afternoon"] },
            { "name": "ものづくり関連", "examples": ["hammer", "wood", "nail", "build", "cut", "tool", "make"] }
          ],
          "assessment": "4択クイズ・穴埋め・絵と単語マッチング"
        },
        {
          "level": 2, "grade": 1, "cefr": "A1+",
          "theme": "動詞の活用・基本フレーズ",
          "target_words": 200,
          "categories": [
            { "name": "不規則動詞", "examples": ["go-went", "come-came", "see-saw", "have-had", "make-made"] },
            { "name": "副詞・前置詞", "examples": ["always", "usually", "often", "sometimes", "in", "on", "at", "under"] },
            { "name": "疑問詞", "examples": ["what", "where", "when", "who", "why", "how"] },
            { "name": "趣味・スポーツ", "examples": ["soccer", "baseball", "music", "game", "cooking", "fishing"] }
          ],
          "assessment": "文脈問題・並び替え・日本語→英語"
        },
        {
          "level": 3, "grade": 2, "cefr": "A2",
          "theme": "抽象語彙・熟語",
          "target_words": 300,
          "categories": [
            { "name": "感情・状態", "examples": ["excited", "surprised", "worried", "proud", "disappointed"] },
            { "name": "熟語・イディオム", "examples": ["look for", "give up", "take care of", "be good at", "get up"] },
            { "name": "接続詞", "examples": ["because", "although", "however", "therefore", "while", "when"] },
            { "name": "職業・社会", "examples": ["doctor", "engineer", "carpenter", "designer", "volunteer"] }
          ],
          "assessment": "長文中の語彙問題・言い換え・文章完成"
        },
        {
          "level": 4, "grade": 2, "cefr": "A2+",
          "theme": "コロケーション・語彙の広がり",
          "target_words": 200,
          "categories": [
            { "name": "コロケーション", "examples": ["make a mistake", "do homework", "take a photo", "have fun"] },
            { "name": "反意語・類義語", "examples": ["increase/decrease", "similar/different", "important/necessary"] },
            { "name": "技術・環境", "examples": ["technology", "environment", "recycle", "energy", "design"] }
          ],
          "assessment": "コロケーション問題・類義語選択・文章作成"
        },
        {
          "level": 5, "grade": 3, "cefr": "B1",
          "theme": "発展語彙・英検3級-準2級レベル",
          "target_words": 200,
          "categories": [
            { "name": "抽象概念", "examples": ["achieve", "contribute", "influence", "promote", "require"] },
            { "name": "時事・社会", "examples": ["global", "culture", "tradition", "opportunity", "challenge"] },
            { "name": "学術語彙", "examples": ["explain", "describe", "compare", "suggest", "conclude"] }
          ],
          "assessment": "英検形式問題・エッセイ中の語彙使用"
        }
      ]
    },
    "grammar": {
      "description": "文法力：文構造・時制・品詞の理解と運用",
      "levels": [
        {
          "level": 1, "grade": 1, "cefr": "A1",
          "units": [
            { "id": "g1-1", "title": "be動詞（am/is/are）", "points": ["肯定文", "否定文", "疑問文", "短縮形"], "example": "I am Souma. This is a hammer." },
            { "id": "g1-2", "title": "一般動詞の現在形", "points": ["肯定文", "否定文（don't）", "疑問文（Do you...?）", "3単現のs"], "example": "I play soccer. He likes wood." },
            { "id": "g1-3", "title": "疑問詞", "points": ["What/Where/When/Who/Why/How", "疑問詞+be動詞", "疑問詞+一般動詞"], "example": "What is this? Where do you live?" },
            { "id": "g1-4", "title": "代名詞", "points": ["人称代名詞（I/you/he/she/it/we/they）", "所有格", "目的格"], "example": "He is my friend. I like him." },
            { "id": "g1-5", "title": "命令文・感嘆文", "points": ["命令文（動詞で始まる）", "否定命令（Don't...）", "Let's..."], "example": "Open the door. Don't run. Let's build it!" }
          ]
        },
        {
          "level": 2, "grade": 1, "cefr": "A1+",
          "units": [
            { "id": "g2-1", "title": "現在進行形", "points": ["be動詞+動詞ing", "否定・疑問", "今まさにしていること"], "example": "I am building a chair now." },
            { "id": "g2-2", "title": "一般動詞の過去形", "points": ["規則動詞（-ed）", "不規則動詞", "過去の否定・疑問"], "example": "I made a table yesterday." },
            { "id": "g2-3", "title": "過去進行形", "points": ["was/were+動詞ing", "過去のある時点での動作"], "example": "I was cutting wood at 3 PM." },
            { "id": "g2-4", "title": "未来形（will/be going to）", "points": ["willの用法", "be going toの用法", "違いの理解"], "example": "I will be a carpenter. I'm going to make a shelf." }
          ]
        },
        {
          "level": 3, "grade": 2, "cefr": "A2",
          "units": [
            { "id": "g3-1", "title": "助動詞", "points": ["can/could", "must/have to", "should", "may/might"], "example": "You must wear gloves. You should measure twice." },
            { "id": "g3-2", "title": "不定詞", "points": ["名詞的用法", "副詞的用法", "形容詞的用法"], "example": "I want to build a house. I have tools to use." },
            { "id": "g3-3", "title": "動名詞", "points": ["動詞のing形（主語・目的語）", "不定詞との使い分け"], "example": "Building is fun. I enjoy making things." },
            { "id": "g3-4", "title": "比較", "points": ["比較級（-er/more）", "最上級（-est/most）", "as...as"], "example": "This hammer is heavier than that one." },
            { "id": "g3-5", "title": "接続詞", "points": ["when/if/because/that/although"], "example": "If you practice, you will improve." }
          ]
        },
        {
          "level": 4, "grade": 2, "cefr": "A2+",
          "units": [
            { "id": "g4-1", "title": "受動態", "points": ["be動詞+過去分詞", "by+行為者", "様々な時制の受動態"], "example": "This table was made by my grandfather." },
            { "id": "g4-2", "title": "現在完了形", "points": ["have+過去分詞", "経験・継続・完了・結果"], "example": "I have built three shelves so far." },
            { "id": "g4-3", "title": "関係代名詞", "points": ["who/which/that", "主格・目的格"], "example": "The tool that I use most is a saw." }
          ]
        },
        {
          "level": 5, "grade": 3, "cefr": "B1",
          "units": [
            { "id": "g5-1", "title": "仮定法", "points": ["If+過去形, would...（仮定法過去）", "I wish..."], "example": "If I had more tools, I would build a house." },
            { "id": "g5-2", "title": "間接疑問文", "points": ["疑問詞+主語+動詞の語順"], "example": "I know where the workshop is." },
            { "id": "g5-3", "title": "分詞構文", "points": ["現在分詞・過去分詞の形容詞的用法"], "example": "The house built by him is beautiful." },
            { "id": "g5-4", "title": "話法", "points": ["直接話法・間接話法の転換"], "example": "He said that he wanted to be a carpenter." }
          ]
        }
      ]
    },
    "listening": {
      "description": "リスニング力：音声理解・ディクテーション",
      "levels": [
        { "level": 1, "grade": 1, "cefr": "A1", "content": ["数字・アルファベット聞き取り", "短い会話（2-3文）", "簡単な指示を聞いて行動"], "speed": "ゆっくり（100wpm以下）", "assessment": "4択・○×・絵選択" },
        { "level": 2, "grade": 1, "cefr": "A1+", "content": ["日常会話の聞き取り", "時間・場所の聞き取り", "短いモノローグ"], "speed": "やや遅め（110wpm）", "assessment": "空欄補充・内容一致" },
        { "level": 3, "grade": 2, "cefr": "A2", "content": ["学校・家庭の会話", "ニュース・アナウンス", "ディクテーション（短文）"], "speed": "標準（120wpm）", "assessment": "内容真偽・要約" },
        { "level": 4, "grade": 2, "cefr": "A2+", "content": ["インタビュー・討論", "電話会話", "ディクテーション（段落）"], "speed": "やや速め（130wpm）", "assessment": "詳細理解・推測" },
        { "level": 5, "grade": 3, "cefr": "B1", "content": ["英語ニュース（NHK World）", "TED-Ed（字幕なし）", "英検3級リスニング形式"], "speed": "ネイティブ速度（140wpm+）", "assessment": "英検形式・要点まとめ" }
      ]
    },
    "speaking": {
      "description": "スピーキング力：発音・流暢さ・表現力",
      "levels": [
        { "level": 1, "grade": 1, "cefr": "A1", "content": ["アルファベット発音", "数字・色・形の発音", "簡単な自己紹介（名前・年齢・好きなもの）"], "tasks": ["音読（単語・短文）", "チャンツ・歌"], "assessment": "発音チェック・暗唱" },
        { "level": 2, "grade": 1, "cefr": "A1+", "content": ["日常会話の応答", "好きなものの説明", "簡単な質問への回答"], "tasks": ["ロールプレイ（買い物・道案内）", "1分スピーチ（好きなもの）"], "assessment": "会話シミュレーション" },
        { "level": 3, "grade": 2, "cefr": "A2", "content": ["経験を語る", "意見を述べる（I think...）", "理由を説明する（because...）"], "tasks": ["スピーチ（夢・将来）", "ペアディスカッション"], "assessment": "流暢さ・内容・文法" },
        { "level": 4, "grade": 2, "cefr": "A2+", "content": ["プレゼンテーション", "議論・説得", "感情を込めた表現"], "tasks": ["2-3分プレゼン", "ディベート入門"], "assessment": "IELTS Speaking形式（初級）" },
        { "level": 5, "grade": 3, "cefr": "B1", "content": ["抽象的トピックの議論", "即興スピーチ", "インタビュー応答"], "tasks": ["英検3級面接形式", "TEDスタイルスピーチ"], "assessment": "英検スピーキング基準" }
      ]
    },
    "reading": {
      "description": "リーディング力：読解・速読・推測力",
      "levels": [
        { "level": 1, "grade": 1, "cefr": "A1", "text_length": "50-100語", "text_types": ["絵日記", "簡単な説明文", "掲示・看板"], "skills": ["単語の意味推測", "大意把握"], "assessment": "4択・○×・絵マッチング" },
        { "level": 2, "grade": 1, "cefr": "A1+", "text_length": "100-150語", "text_types": ["手紙・メール", "日記", "自己紹介文"], "skills": ["段落の要点把握", "時系列の理解"], "assessment": "内容一致・並び替え" },
        { "level": 3, "grade": 2, "cefr": "A2", "text_length": "150-250語", "text_types": ["説明文", "物語文", "インタビュー記事"], "skills": ["主題・要旨の把握", "筆者の意図推測"], "assessment": "内容真偽・要約・記述" },
        { "level": 4, "grade": 2, "cefr": "A2+", "text_length": "250-350語", "text_types": ["論説文", "ニュース記事", "紹介文"], "skills": ["事実と意見の区別", "論理展開の把握"], "assessment": "英検形式・記述式" },
        { "level": 5, "grade": 3, "cefr": "B1", "text_length": "350-500語", "text_types": ["社会的テーマの文章", "グラフ付き説明文", "複数文書の読み比べ"], "skills": ["批判的読解", "情報統合"], "assessment": "英検3級〜準2級形式" }
      ]
    },
    "writing": {
      "description": "ライティング力：作文・英文構成・表現",
      "levels": [
        { "level": 1, "grade": 1, "cefr": "A1", "tasks": ["単語の書き取り", "短文の書き写し", "穴埋め作文（3-5文）"], "focus": "基本文型・スペリング", "word_count": "20-30語", "assessment": "文法正確さ・スペリング" },
        { "level": 2, "grade": 1, "cefr": "A1+", "tasks": ["自己紹介文（5-7文）", "好きなものの説明", "絵を見て説明"], "focus": "接続詞の使用・文のつながり", "word_count": "40-60語", "assessment": "内容・文法・語彙" },
        { "level": 3, "grade": 2, "cefr": "A2", "tasks": ["日記・メール（80-100語）", "経験を語る文章", "理由を含む意見文"], "focus": "段落構成・理由の説明", "word_count": "80-100語", "assessment": "構成・内容・言語使用" },
        { "level": 4, "grade": 2, "cefr": "A2+", "tasks": ["説明文（100-120語）", "比較・対比の文章", "問題提起と解決策"], "focus": "論理的展開・つなぎ言葉", "word_count": "100-120語", "assessment": "英検形式ライティング" },
        { "level": 5, "grade": 3, "cefr": "B1", "tasks": ["エッセイ（120-150語）", "賛否を述べる意見文", "グラフ・図の説明"], "focus": "説得力・独自性・適切な語彙", "word_count": "120-150語", "assessment": "英検3級〜準2級ライティング形式" }
      ]
    },
    "communication": {
      "description": "実用コミュニケーション力：場面別会話・デジタル英語",
      "levels": [
        {
          "level": 1, "grade": 1, "cefr": "A1",
          "scenarios": [
            { "scene": "自己紹介", "phrases": ["My name is...", "I am ... years old.", "I like...", "Nice to meet you."] },
            { "scene": "買い物", "phrases": ["How much is this?", "I'll take it.", "Do you have...?"] },
            { "scene": "道を聞く", "phrases": ["Excuse me.", "Where is...?", "Turn left/right.", "Go straight."] }
          ]
        },
        {
          "level": 2, "grade": 1, "cefr": "A1+",
          "scenarios": [
            { "scene": "学校生活", "phrases": ["Can I borrow...?", "I don't understand.", "Please say that again."] },
            { "scene": "電話・メッセージ", "phrases": ["Can I speak to...?", "Just a moment.", "I'll call back later."] },
            { "scene": "趣味の話", "phrases": ["I'm into...", "Have you ever tried...?", "It's really fun!"] }
          ]
        },
        {
          "level": 3, "grade": 2, "cefr": "A2",
          "scenarios": [
            { "scene": "意見を述べる", "phrases": ["I think...", "In my opinion...", "I agree/disagree because..."] },
            { "scene": "ものづくりの説明", "phrases": ["First, you need to...", "Then, attach the...", "Finally, check if..."] },
            { "scene": "SNS・デジタル", "phrases": ["DM me.", "Check out this post.", "I posted a video about..."] }
          ]
        },
        {
          "level": 4, "grade": 2, "cefr": "A2+",
          "scenarios": [
            { "scene": "プレゼン・発表", "phrases": ["Today I'd like to talk about...", "As you can see...", "Any questions?"] },
            { "scene": "問題解決", "phrases": ["The problem is...", "One solution is...", "What if we...?"] },
            { "scene": "異文化交流", "phrases": ["In Japan, we...", "That's interesting!", "How do you say... in English?"] }
          ]
        },
        {
          "level": 5, "grade": 3, "cefr": "B1",
          "scenarios": [
            { "scene": "議論・ディベート", "phrases": ["On the other hand...", "That's a valid point, but...", "Evidence shows that..."] },
            { "scene": "将来・夢の話", "phrases": ["I aspire to be...", "My goal is to...", "I believe that..."] },
            { "scene": "グローバル英語", "phrases": ["Could you clarify...?", "I'm not sure I follow.", "Let me rephrase that."] }
          ]
        }
      ]
    }
  }
}
